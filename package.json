{
  "name": "sparebridge",
  "version": "1.0.0",
  "description": "Emergency Cross-Plant Spare Part Matching — CAP Application",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy": "cds deploy --to sqlite",
    "watch-breakdown-ui": "cds watch --open com.sparebridge.breakdownui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "dependencies": {
    "@sap/cds": "^9",
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0",
    "express": "^4"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      }
    },
    "[production]": {
      "requires": {
        "auth": "dummy",
        "db": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          }
        }
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/breakdown-ui"
  ]
}
