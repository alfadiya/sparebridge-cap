{
  "name": "sparebridge",
  "version": "1.0.0",
  "description": "Emergency Cross-Plant Spare Part Matching — CAP Application",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "deploy": "cds deploy --to sqlite"
  },
  "dependencies": {
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": { "url": ":memory:" }
      }
    }
  }
}
